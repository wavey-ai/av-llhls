{
  "name": "@wavey-ai/av-llhls",
  "version": "0.1.0",
  "description": "Low-latency audio frame transport for LL-HLS, SoundKit framing, and Rust Opus WASM decoding.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "node scripts/build.mjs && tsc --emitDeclarationOnly",
    "clean": "node scripts/clean.mjs",
    "prepare": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "keywords": [
    "ll-hls",
    "audio",
    "opus",
    "wasm",
    "soundkit",
    "multitrack"
  ],
  "author": "wavey-ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wavey-ai/av-llhls.git"
  },
  "peerDependencies": {
    "hls.js": "^1.6.16"
  },
  "peerDependenciesMeta": {
    "hls.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  }
}
